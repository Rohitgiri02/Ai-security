# Copy this file to .env and fill in your values

# Backend Configuration
PORT=9090
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
# You can provide multiple origins separated by commas.
# Example: FRONTEND_URL=http://localhost:3001,http://localhost:3002

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/ai_code_analyzer

# Clerk (Backend)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub API Configuration (for repository scanning)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API Configuration (Llama model)
OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# GitHub Webhook Configuration
GITHUB_WEBHOOK_SECRET=your_secret_key_here
